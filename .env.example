# Netra — example environment file.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file is committed.
# This file holds NON-SECRET configuration only. See SECURITY note in src/config/env.ts.

# AWS / sync
AWS_REGION=ap-south-1
SYNC_ENDPOINT=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod/attendance
AWS_COGNITO_IDENTITY_POOL_ID=ap-south-1:00000000-0000-0000-0000-000000000000

# Recognition tuning
MATCH_THRESHOLD=0.6
LIVENESS_BLINK_THRESHOLD=0.45
LIVENESS_SMILE_THRESHOLD=0.5
LIVENESS_YAW_DEGREES=20

# Model
MODEL_PATH=mobilefacenet_int8.tflite
